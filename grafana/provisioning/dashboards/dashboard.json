                    "datasource": {
                        "type": "postgres",
                        "uid": "PostgreSQL"
                    },
                    "editorMode": "code",
                    "format": "time_series",
                    "rawQuery": true,
                    "rawSql": "SELECT timestamp AS \"time\", value, sensor_type AS metric FROM sensor_data WHERE $__timeFilter(timestamp) ORDER BY timestamp ASC;",
                    "refId": "A"
