# ======================================================
#  Environment Configuration Matrix - LSS Project
#  This file centralizes all operational variables,
#  database credentials, and network infrastructure targets.
# ======================================================

# ------------------------------------------------------
#  Relational Database Configuration (PostgreSQL)
# ------------------------------------------------------
# The container service name acting as the target hostname within the Docker network
DB_HOST=database

# The default database schema name initialized during the container setup
DB_NAME=iot_db

# The administrative identity user for database transaction processing
DB_USER=iot_user

# The secure access password assigned to the database administrative identity
DB_PASSWORD=iot_password

# ------------------------------------------------------
#  Message Broker Configuration (Eclipse Mosquitto)
# ------------------------------------------------------
# The container service name acting as the target broker within the Docker network
MQTT_BROKER=mosquitto

# The standard unencrypted communication port bound to the broker interface
MQTT_PORT=1883
